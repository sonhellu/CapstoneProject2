{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions"
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "hicampus-acd31",
          "appId": "1:771163168949:android:c38589b42d47c1f300defc",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "hicampus-acd31",
          "appId": "1:771163168949:ios:5eeccd3f3c84a4e200defc",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "hicampus-acd31",
          "configurations": {
            "android": "1:771163168949:android:c38589b42d47c1f300defc",
            "ios": "1:771163168949:ios:5eeccd3f3c84a4e200defc",
            "web": "1:771163168949:web:c8b7bca16d97b0a500defc",
            "windows": "1:771163168949:web:42887cfdd1a8ede000defc"
          }
        }
      }
    }
  },
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
