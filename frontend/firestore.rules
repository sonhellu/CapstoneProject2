rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────── Shared helpers ──────────────────────────────

    function signedIn()      { return request.auth != null; }
    function uid()           { return request.auth.uid; }
    function isOwner(userId) { return signedIn() && uid() == userId; }

    /// Deterministic conversation / request ID: sorted(a, b) = "min_max".
    /// Must stay in sync with ChatService._sortedId().
    function sortedId(a, b) {
      return a < b ? a + '_' + b : b + '_' + a;
    }

    function validConversationId(cid, parts) {
      return parts is list
        && parts.size() == 2
        && cid == sortedId(parts[0], parts[1]);
    }

    function validChatRequestId(rid, senderId, receiverId) {
      return rid == sortedId(senderId, receiverId);
    }

    // ─────────────────────────── /users ──────────────────────────────────────

    match /users/{userId} {
      allow get:    if signedIn();
      allow list:   if signedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ─────────────────────────── /chat_requests ──────────────────────────────
    //
    // State machine: none ──► pending ──► active ──► disconnected
    //                                                      │
    //                         pending ◄────────────────────┘  (reconnect)
    //
    // Decline = DELETE (returns pair to none state; either user may re-initiate).

    match /chat_requests/{requestId} {

      // Participants may read their own requests.
      // Allow missing-doc reads (used in sendRequest transaction).
      allow get: if signedIn()
          && (
               !exists(/databases/$(database)/documents/chat_requests/$(requestId))
            || resource.data.senderId   == uid()
            || resource.data.receiverId == uid()
          );

      // Used by incomingRequestsStream (query filtered by receiverId == uid).
      allow list: if signedIn()
          && (
               resource.data.senderId   == uid()
            || resource.data.receiverId == uid()
          );

      // CREATE: new pending request.
      allow create: if signedIn()
          && request.resource.data.senderId  == uid()
          && request.resource.data.status    == 'pending'
          && request.resource.data.keys().hasAll([
               'senderId', 'receiverId', 'senderInfo',
               'receiverInfo', 'status', 'createdAt'
             ])
          && validChatRequestId(
               requestId,
               request.resource.data.senderId,
               request.resource.data.receiverId
             );

      // UPDATE: four allowed transitions —
      //   1. pending  → active       (receiver accepts)
      //   2. pending  → declined     (sender or receiver declines — legacy, kept for safety)
      //   3. active   → disconnected (any participant soft-unmatch)
      //   4. disconnected/declined → pending  (any participant reconnects)
      allow update: if signedIn()
          && (
               // ① Receiver accepts: pending → active
               (
                 resource.data.receiverId == uid()
                 && resource.data.status  == 'pending'
                 && request.resource.data.status == 'active'
               )
               // ② Sender or receiver declines: pending → declined
               || (
                 (resource.data.senderId == uid() || resource.data.receiverId == uid())
                 && resource.data.status  == 'pending'
                 && request.resource.data.status == 'declined'
               )
               // ③ Soft unmatch: active → disconnected
               || (
                 (resource.data.senderId == uid() || resource.data.receiverId == uid())
                 && resource.data.status == 'active'
                 && request.resource.data.status == 'disconnected'
                 && request.resource.data.disconnectedBy == uid()
               )
               // ④ Reconnect: disconnected or declined → pending (roles may swap)
               || (
                 (resource.data.status == 'disconnected' || resource.data.status == 'declined')
                 && request.resource.data.status   == 'pending'
                 && request.resource.data.senderId == uid()
                 && validChatRequestId(requestId, request.resource.data.senderId, request.resource.data.receiverId)
                 && (
                      (resource.data.senderId == request.resource.data.senderId && resource.data.receiverId == request.resource.data.receiverId)
                   || (resource.data.senderId == request.resource.data.receiverId && resource.data.receiverId == request.resource.data.senderId)
                 )
               )
             );

      // DELETE: any participant may delete (decline = return to none state).
      allow delete: if signedIn()
          && (
               resource.data.senderId   == uid()
            || resource.data.receiverId == uid()
          );
    }

    // ─────────────────────────── /conversations ──────────────────────────────

    match /conversations/{convId} {

      // get: allow missing-doc reads (acceptRequest transaction reads before write).
      // When doc exists, only participants may read.
      allow get: if signedIn()
          && (
               !exists(/databases/$(database)/documents/conversations/$(convId))
            || uid() in resource.data.participants
          );

      // list: query must filter by participants arrayContains uid.
      allow list: if signedIn()
          && uid() in resource.data.participants;

      // create: receiver writes conversation atomically when accepting.
      allow create: if signedIn()
          && validConversationId(convId, request.resource.data.participants)
          && uid() in request.resource.data.participants
          && request.resource.data.participants.size() == 2
          && request.resource.data.keys().hasAll([
               'participants', 'participantInfo', 'lastMessage',
               'lastMessageAt', 'unreadCounts', 'status',
               'requestedBy', 'createdAt'
             ])
          && request.resource.data.status       == 'active'
          && request.resource.data.lastMessage  == ''
          && request.resource.data.requestedBy  is string
          && request.resource.data.requestedBy  in request.resource.data.participants
          && request.resource.data.unreadCounts[request.resource.data.participants[0]] == 0
          && request.resource.data.unreadCounts[request.resource.data.participants[1]] == 0
          && request.resource.data.unreadCounts.keys().hasOnly([
               request.resource.data.participants[0],
               request.resource.data.participants[1]
             ])
          && request.resource.data.participantInfo[request.resource.data.participants[0]] is map
          && request.resource.data.participantInfo[request.resource.data.participants[1]] is map;

      // update: any participant may update metadata or change status.
      // participants array is immutable; status may only be active or disconnected.
      allow update: if signedIn()
          && uid() in resource.data.participants
          && request.resource.data.participants == resource.data.participants
          && (
               !('status' in request.resource.data)
            || request.resource.data.status == 'active'
            || request.resource.data.status == 'disconnected'
          );

      // delete: participants may delete (not normally used but kept for admin cleanup).
      allow delete: if signedIn()
          && uid() in resource.data.participants;

      // ───────────────────── /conversations/{convId}/messages ─────────────────

      match /messages/{msgId} {

        allow read: if signedIn()
            && uid() in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;

        allow create: if signedIn()
            && request.resource.data.keys().hasAll([
                 'senderId', 'content', 'timestamp', 'isRead'
               ])
            && (
              // Normal message from a participant in an active conversation.
              (
                request.resource.data.senderId == uid()
                && uid() in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
                && get(/databases/$(database)/documents/conversations/$(convId)).data.get('status', 'active') == 'active'
              )
              // System welcome message written by the receiver accepting the request.
              || (
                request.resource.data.senderId == 'system'
                && request.resource.data.get('type', '') == 'system'
                && exists(/databases/$(database)/documents/chat_requests/$(convId))
                && get(/databases/$(database)/documents/chat_requests/$(convId))
                     .data.receiverId == uid()
              )
            );

        // Participants may mark messages as read.
        allow update: if signedIn()
            && uid() in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;

        allow delete: if false;
      }
    }

    // ─────────────────────── /users/{uid}/schedule_activities ───────────────────

    match /users/{userId}/schedule_activities/{activityId} {
      allow read, write: if isOwner(userId);
    }

    // ─────────────────────────── Catch-all deny ──────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
