APP_ENV=development
SECRET_KEY=change-me-in-production
PORT=8000

# Railway Postgres usually injects DATABASE_URL automatically when the
# Postgres service is attached to this backend service.
DATABASE_URL=

POSTGRES_USER=hicampus
POSTGRES_PASSWORD=hicampus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hicampus

NAVER_MAP_CLIENT_ID=your_ncp_client_id
NAVER_MAP_CLIENT_SECRET=your_ncp_client_secret
PUBLIC_DATA_SERVICE_KEY=your_public_data_service_key
GOOGLE_TRANSLATOR_API_KEY=your_google_translator_api_key

# Paste the full Firebase service account JSON into this Railway variable.
FIREBASE_SERVICE_ACCOUNT_JSON=
